# NVIDIA API Configuration
# Get your key from https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-nTBHsh-xxx

# Drupal API Configuration
# Option 1: API Token (preferred for production)
DRUPAL_API_TOKEN=your-drupal-api-token

# Option 2: Username/Password (for development/testing)
DRUPAL_USERNAME=admin
DRUPAL_PASSWORD=your-password
DRUPAL_BASE_URL=https://example.com

# Ollama Configuration
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b
