#!/usr/bin/env python3
"""
agent-exe: CLI launcher for Drupal AI agents.

author = "Inventions4All - github:TWeb79"

Usage:
    agent-exe <agent> [options]
    agent-exe list
    agent-exe --help

Examples:
    agent-exe design
    agent-exe design -llm nvidia --goal "Create a theme"
"""

import argparse
import json
import os
import subprocess
import sys
import urllib.request
import urllib.error

# Load environment variables from .env file
_env_file = os.path.join(os.path.dirname(os.path.abspath(__file__)), ".env")
if os.path.exists(_env_file):
    with open(_env_file, "r", encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if line and not line.startswith("#") and "=" in line:
                key, _, value = line.partition("=")
                os.environ.setdefault(key.strip(), value.strip())

AGENTS_DIR = os.path.dirname(os.path.abspath(__file__))
OUTPUT_DIR = "output"


def load_agent_module(agent_key: str):
    """Import agent-specific module with its tools."""
    agent_folder = f"agent_{agent_key}"
    module_path = os.path.join(AGENTS_DIR, agent_folder, f"{agent_folder.split('_')[1]}_agent.py")
    if os.path.exists(module_path):
        import importlib.util
        spec = importlib.util.spec_from_file_location(f"{agent_folder}_tools", module_path)
        module = importlib.util.module_from_spec(spec)
        spec.loader.exec_module(module)
        return module
    return None


AGENTS = {
    "design": {"folder": "agent_design", "label": "Theme Design Agent"},
    "component": {"folder": "agent_component", "label": "Component Development Agent"},
    "assembly": {"folder": "agent_assembly", "label": "Website Assembly Agent"},
}

LLM_PROVIDERS = {
    "ollama": {"url": "http://localhost:11434", "model": "qwen3.5:9b"},
    "nvidia": {"url": "https://integrate.api.nvidia.com/v1", "model": "openai/gpt-oss-20b"},
}


def read_file(path: str) -> str:
    with open(path, "r", encoding="utf-8") as f:
        return f.read()


def check_ollama(model: str = None) -> bool:
    try:
        req = urllib.request.Request(f"{LLM_PROVIDERS['ollama']['url']}/api/tags")
        with urllib.request.urlopen(req, timeout=3) as resp:
            return any((model or LLM_PROVIDERS["ollama"]["model"]) in m["name"] for m in json.loads(resp.read()).get("models", []))
    except Exception:
        return False


def call_llm(system_prompt: str, user_message: str, provider: str = "ollama", model: str = None) -> str:
    """Route to appropriate LLM provider."""
    if provider == "nvidia":
        api_key = os.environ.get("NVIDIA_API_KEY")
        if not api_key:
            return "NVIDIA_API_KEY not set."
        payload = json.dumps({"model": LLM_PROVIDERS["nvidia"]["model"],
            "messages": [{"role": "system", "content": system_prompt}, {"role": "user", "content": user_message}],
            "max_tokens": 8192}).encode("utf-8")
        req = urllib.request.Request(f"{LLM_PROVIDERS['nvidia']['url']}/chat/completions", data=payload,
            headers={"Content-Type": "application/json", "Authorization": f"Bearer {api_key}"})
    else:
        payload = json.dumps({"model": model or LLM_PROVIDERS["ollama"]["model"],
            "system": system_prompt, "prompt": user_message, "stream": False,
            "options": {"num_predict": 8192}}).encode("utf-8")
        req = urllib.request.Request(f"{LLM_PROVIDERS['ollama']['url']}/api/generate", data=payload,
            headers={"Content-Type": "application/json"})
    
    try:
        with urllib.request.urlopen(req, timeout=300) as resp:
            data = json.loads(resp.read())
            return data.get("response", "") if provider == "ollama" else data.get("choices", [{}])[0].get("message", {}).get("content", "")
    except Exception as e:
        return f"Error calling {provider}: {e}"


def run_interactive(agent_key: str, system_prompt: str, drupal_url: str = None, 
                   api_token: str = None, username: str = None, password: str = None, llm_provider: str = "ollama"):
    model_name = LLM_PROVIDERS.get(llm_provider, LLM_PROVIDERS["ollama"])["model"]
    agent_module = load_agent_module(agent_key)
    
    print(f"\n{'='*60}")
    print(f"  {AGENTS[agent_key]['label']}")
    print(f"  Model: {model_name} via {llm_provider}")
    print(f"{'='*60}")
    print("  Commands: 'quit', 'exit', 'q' to exit.\n")
    
    history = []
    while True:
        try:
            user_input = input("You > ").strip()
        except (EOFError, KeyboardInterrupt):
            print("\nExiting.")
            sys.exit(0)
        
        if not user_input or user_input.lower() in ("quit", "exit", "q"):
            break
        
        history.append(f"User: {user_input}")
        response = call_llm(system_prompt, "\n".join(history) + "\nAssistant:", llm_provider)
        print(f"\nAgent > {response}")
        
        # Use agent module's publish function if available
        if drupal_url and '"action": "publish_to_drupal"' in response.lower():
            try:
                parsed = json.loads(response)
                payloads = parsed.get("parameters", {}).get("payloads", [])
                if agent_module and hasattr(agent_module, "publish_to_drupal"):
                    results = agent_module.publish_to_drupal(drupal_url, api_token, username, password, payloads)
                else:
                    results = _publish_fallback(drupal_url, api_token, username, password, payloads)
                for r in results:
                    status = "✓" if r["status"] == "success" else "✗"
                    print(f"  {status} Step {r['step']}: {r['endpoint']} ({r['status']})")
            except json.JSONDecodeError:
                pass
        history.append(f"Assistant: {response}")
        print()


def _publish_fallback(drupal_url: str, api_token: str, username: str, password: str, payloads: list) -> list:
    """Fallback publish function with basic auth support."""
    import base64
    auth_header = None
    if api_token:
        auth_header = f"Bearer {api_token}"
    elif username and password:
        auth_header = f"Basic {base64.b64encode(f'{username}:{password}'.encode()).decode()}"
    else:
        api_token = os.environ.get("DRUPAL_API_TOKEN")
        if api_token:
            auth_header = f"Bearer {api_token}"
        else:
            username = os.environ.get("DRUPAL_USERNAME")
            password = os.environ.get("DRUPAL_PASSWORD")
            if username and password:
                auth_header = f"Basic {base64.b64encode(f'{username}:{password}'.encode()).decode()}"
    
    if not auth_header:
        return [{"error": "No Drupal auth configured"}]
    
    headers = {"Content-Type": "application/vnd.api+json", "Authorization": auth_header}
    results = []
    
    for i, payload in enumerate(payloads):
        try:
            url = f"{drupal_url.rstrip('/')}{payload.get('endpoint', '')}"
            req = urllib.request.Request(url, data=json.dumps(payload.get("data", {})).encode("utf-8"), 
                headers=headers, method="POST")
            with urllib.request.urlopen(req, timeout=60) as resp:
                results.append({"step": i + 1, "endpoint": payload.get("endpoint"), "status": "success"})
        except Exception as e:
            results.append({"step": i + 1, "endpoint": payload.get("endpoint"), "status": "error", "error": str(e)})
    
    return results


def run_single(agent_key: str, system_prompt: str, goal: str, llm_provider: str = "ollama"):
    model_name = LLM_PROVIDERS.get(llm_provider, LLM_PROVIDERS["ollama"])["model"]
    print(f"\n{'='*60}")
    print(f"  {AGENTS[agent_key]['label']}")
    print(f"  Model: {model_name} via {llm_provider}")
    print(f"{'='*60}\n")
    print(f"Goal: {goal}\n")
    
    response = call_llm(system_prompt, goal, llm_provider)
    print(response)
    
    os.makedirs(OUTPUT_DIR, exist_ok=True)
    output_file = os.path.join(OUTPUT_DIR, f"{agent_key}_{goal.replace(' ', '_')[:30]}.json")
    with open(output_file, "w", encoding="utf-8") as f:
        f.write(response)
    print(f"\n[Output saved to {output_file}]")


def cmd_list():
    print("\nAvailable agents:\n")
    for key, info in AGENTS.items():
        print(f"  {key:12s}  {info['label']}")
    print(f"\n  LLM Providers: {', '.join(LLM_PROVIDERS.keys())}\n")


def main():
    parser = argparse.ArgumentParser(prog="agent-exe", description="Launch Drupal AI agents")
    subparsers = parser.add_subparsers(dest="command")
    subparsers.add_parser("list", help="List agents")
    subparsers.add_parser("models", help="List models")
    
    run_parser = subparsers.add_parser("run", help="Run agent")
    run_parser.add_argument("agent", choices=list(AGENTS.keys()))
    run_parser.add_argument("--llm", "-p", choices=list(LLM_PROVIDERS.keys()), default="ollama")
    run_parser.add_argument("--goal", "-g", default=None)
    run_parser.add_argument("--publish", action="store_true")
    run_parser.add_argument("--drupal-url", default=None)
    run_parser.add_argument("--api-token", default=None)
    run_parser.add_argument("--username", default=None)
    run_parser.add_argument("--password", default=None)
    
    args = parser.parse_args()
    
    if args.command in (None, "list"):
        cmd_list()
        return
    
    if args.command == "models":
        for provider, config in LLM_PROVIDERS.items():
            print(f"  {provider:10s}  {config['model']}")
        return
    
    if args.command == "run":
        if args.llm == "ollama" and not check_ollama():
            print("Ollama model not found.")
            sys.exit(1)
        
        system_prompt = read_file(os.path.join(AGENTS_DIR, AGENTS[args.agent]["folder"], "system_prompt.md"))
        
        if args.goal:
            run_single(args.agent, system_prompt, args.goal, args.llm)
        else:
            run_interactive(args.agent, system_prompt, args.drupal_url, args.api_token, 
                          args.username, args.password, args.llm)


if __name__ == "__main__":
    main()